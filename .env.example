VERCEL_ENV=development
OPENAI_API_KEY=
CLOUDFLARE_AI_GATEWAY=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_URL_NO_SSL=
POSTGRES_USER=
USE_POSTGRES=0
# When USE_POSTGRES=1 the dev server connects to a local pgvector pool.
# Defaults match docker-compose's "db" service (intra-container hostname).
# To reach the same container from the docker host, set
# POSTGRES_HOST=localhost POSTGRES_PORT=5433.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_PASSWORD=password
POSTGRES_DB=verceldb
USE_OLLAMA=0
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://ollama:11434
# Inference backend (mutually exclusive: at most one may be "1").
# USE_OPENAI_API=1 explicitly opts into OpenAI; absent flags also fall back to OpenAI.
# Setting more than one to "1" throws at boot via instrumentation.ts.
USE_OPENAI_API=0
# Local llama-server mode (per-role parallel endpoints). When USE_LLAMA_CPP=1,
# inner/surface/deep route to ports 18091/18092/18093 and embedding to 18094.
# Start servers with tmp/llama.cpp/start-trident-all-mac.sh
USE_LLAMA_CPP=0
LLAMA_CPP_API_KEY=dummy
# LLAMA_CPP_BASE_URL=  # set to override per-role routing (e.g. Router Mode / -np)
# LLAMA_CPP_EMBEDDING_BASE_URL=http://127.0.0.1:18094/v1
NEXT_PUBLIC_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NEXT_PUBLIC_OVERPASS_BASE_URL=https://overpass-api.de
